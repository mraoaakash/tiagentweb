---
import type { Note } from "../types/types";

interface Props {
  notes: Note[];
}

const { notes } = Astro.props;
---

<div class="mx-auto max-w-[44rem] text-center text-sm leading-snug">
  {
    // prettier-ignore
    notes.map((note, index, array) =>
      <span>
        <sup>{note.symbol}</sup>{note.text}{index < array.length - 1 ? ", " : ""}
      </span>
    )
  }
</div>
